# Enforce LF line endings repo-wide.
#
# Without this, a Windows checkout with core.autocrlf=true rewrites LF->CRLF
# in the working tree. Plain-string includes() and multiline regex assertions
# in test/QA scripts false-fail locally while passing in CI. Pinning eol=lf
# keeps the working tree aligned with the LF index for everyone.
* text=auto eol=lf

# Windows-only scripts must stay CRLF to run correctly.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary assets — never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.avif  binary
*.ico   binary
*.icns  binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.mp4   binary
*.webm  binary
*.mov   binary
*.mp3   binary
*.wav   binary
*.zip   binary
*.gz    binary
*.jar   binary
*.keystore binary
*.jks   binary
